@inproceedings{GodfreyBen2025,
author = {Godfrey, Ben},
title = {Practical advice for the creation of effective HPC user documentation},
year = {2024},
isbn = {9798400704192},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3626203.3670621},
doi = {10.1145/3626203.3670621},
abstract = {Understanding what research computing resources are available and how to use them effectively can be a significant barrier to access for students and faculty. Providing user documentation that is accurate and easy to understand is critical to supporting researchers in their work. For the support staff on the Research Computing and Data, Engagement (RCDE) team at Clemson University, maintaining user documentation has been a challenging task. In late 2022, the RCDE team initiated a project to create a new user documentation website using modern tools and a fresh approach. The main goals of this project were to ensure that all content was accurate, make concepts easier to understand, improve the user experience, and decrease the level of effort required by staff to make edits. Throughout the project, we have gained a wealth of experience in this area that will be useful to other HPC centers seeking to improve or create their user documentation.},
booktitle = {Practice and Experience in Advanced Research Computing 2024: Human Powered Computing},
articleno = {83},
numpages = {4},
keywords = {Documentation, HPC, Training, User Education, User Support},
location = {Providence, RI, USA},
series = {PEARC '24}
}

